    "migrate:resolve": "prisma migrate resolve"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.1",
    "@prisma/client": "^5.19.0",
    "zod": "^3.23.8",
    "jsonwebtoken": "^9.0.2",
    "@types/node": "^20.10.5",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "prisma": "^5.19.0",
    "@types/jsonwebtoken": "^9.0.5"
  }
}





