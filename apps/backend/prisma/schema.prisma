// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  tgId      BigInt   @id @db.BigInt
  name      String?
  createdAt DateTime @default(now())

  @@map("admins")
}

model Banner {
  id           String   @id @default(uuid())
  title        String
  subtitle     String?
  description  String
  image        String
  detailsImage String?
  ctaText      String?
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("banners")
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  isActive  Boolean   @default(true)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("categories")
  @@index([slug])
  @@index([isActive, order])
}

model Product {
  id          String     @id @default(uuid())
  title       String
  description String
  price       Int
  images      String[]   @default([])
  sku         String?
  article     String?
  isActive    Boolean    @default(true)
  status      String?    @default("draft") // draft, published
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  categories  Category[]

  @@map("products")
  @@index([isActive, status])
}

model Promo {
  id              String   @id @default(uuid())
  code            String   @unique
  discountPercent Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("promos")
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Order {
  id                String   @id @default(uuid())
  items             Json
  total             Int
  status            String
  tgId              BigInt?  @db.BigInt
  notifyUserStatus  String?  @default("PENDING") // PENDING, SENT, FAILED
  notifyUserError   String?  @db.VarChar(1000)
  notifyUserTgId    BigInt?  @db.BigInt
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("orders")
}

model Review {
  id        String   @id @default(uuid())
  productId String
  tgId      BigInt?  @db.BigInt
  rating    Int
  text      String?
  media     Json?    @default("[]")
  reactions Json?    @default("{}")
  replies   Json?    @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}

model TelegramSubscriber {
  tgId      BigInt   @id @db.BigInt
  username  String?
  firstName String?
  lastName  String?
  avatarUrl String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("telegram_subscribers")
}

model BotFlow {
  id           String            @id @default(uuid())
  key          String            @unique
  name         String
  description  String?
  status       BotFlowStatus     @default(DRAFT)
  version      Int               @default(0)
  entryPoints  Json              @default("[]") // Array of triggers: ["command:start", "callback:menu", "text:hello"]
  startNodeId  String?
  isActive     Boolean           @default(true) // Legacy field, use status instead
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  publishedAt  DateTime?
  steps        BotFlowStep[]     // Legacy relation, use nodes instead
  nodes        BotFlowNode[]
  versions     BotFlowVersion[]
  userStates   BotUserState[]

  @@map("bot_flows")
  @@index([status, version])
  @@index([key])
}

enum BotFlowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BotFlowNode {
  id          String   @id @default(uuid())
  flowId      String
  title       String
  type        BotNodeType
  content     Json     // { text, parseMode, disablePreview, template vars, mediaUrl, etc }
  keyboard    Json?    @default("null") // { type: "inline"|"reply", buttons: [] }
  transitions Json?    @default("null") // { rules: [{ on: "button", buttonId: "...", goto: "nodeId" }, { on: "text", pattern: "...", goto: "nodeId" }, { fallback: "nodeId" }] }
  guards      Json?    @default("null") // { isAdmin: boolean, isSubscribed: boolean, flags: {}, custom: {} }
  effects     Json?    @default("null") // { logEvent: string, apiCall: {}, notifyAdmin: boolean, setFlag: {}, deleteAfterMs: number, editAnimation: {} }
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  flow        BotFlow  @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@map("bot_flow_nodes")
  @@index([flowId])
  @@index([flowId, order])
}

enum BotNodeType {
  MESSAGE
  MEDIA
  INPUT
  ACTION
  MENU
}

model BotFlowVersion {
  id                String   @id @default(uuid())
  flowId            String
  version           Int
  snapshot          Json     // Immutable snapshot: { flow: {...}, nodes: [...] }
  publishedByTgId   BigInt?  @db.BigInt
  createdAt         DateTime @default(now())
  flow              BotFlow  @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@map("bot_flow_versions")
  @@unique([flowId, version])
  @@index([flowId])
}

model BotUserState {
  id                  String   @id @default(uuid())
  telegramUserId      BigInt   @db.BigInt
  activeFlowId        String?
  activeFlowVersion   Int?
  currentNodeId       String?
  context             Json     @default("{}") // User context: flags, variables, etc
  lastMessageId       Int?
  updatedAt           DateTime @updatedAt
  flow                BotFlow? @relation(fields: [activeFlowId], references: [id], onDelete: SetNull)

  @@map("bot_user_states")
  @@unique([telegramUserId])
  @@index([telegramUserId])
  @@index([activeFlowId])
}

model BotFlowStep {
  id        String   @id @default(uuid())
  flowId    String
  order     Int
  type      String   // TEXT, PHOTO, MEDIA, BUTTONS
  payload   Json
  createdAt DateTime @default(now())
  flow      BotFlow  @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@map("bot_flow_steps")
  @@index([flowId])
}

