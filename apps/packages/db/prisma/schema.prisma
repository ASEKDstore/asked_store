// Prisma schema for ASKED Store

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model (extends Telegram user info)
model User {
  id         String   @id @default(uuid())
  tgId       BigInt   @unique @db.BigInt
  username   String?
  firstName  String?
  lastName   String?
  photoUrl   String?  // Telegram user photo URL
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  userRoles  UserRole[]

  @@map("users")
  @@index([tgId])
}

// Role model (RBAC roles: user, admin, moderator, etc.)
model Role {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "user", "admin", "moderator"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userRoles   UserRole[]
  permissions RolePermission[]

  @@map("roles")
  @@index([name])
}

// Permission model (RBAC permissions: resource:action)
model Permission {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "user:read", "product:create", "order:delete"
  description String?
  resource    String   // e.g., "user", "product", "order"
  action      String   // e.g., "read", "create", "update", "delete"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  rolePermissions RolePermission[]

  @@map("permissions")
  @@index([name])
  @@index([resource, action])
}

// Junction table: User <-> Role (many-to-many)
model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
  @@index([userId])
  @@index([roleId])
}

// Junction table: Role <-> Permission (many-to-many)
model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  // Relations
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
  @@index([roleId])
  @@index([permissionId])
}

// Settings model - configuration key-value store with scopes
model Settings {
  id        String    @id @default(uuid())
  key       String    @unique
  value     Json      // JSON value stored as JSONB
  scope     String    // Enum: global, bot, channel, webapp
  updatedBy String?   // User ID who last updated
  updatedAt DateTime  @updatedAt
  createdAt DateTime  @default(now())

  @@map("settings")
  @@index([key])
  @@index([scope])
}

// Audit Log model - tracks changes to settings and other admin actions
model AuditLog {
  id        String   @id @default(uuid())
  userId    String   // User ID who performed the action
  action    String   // Action type: settings.update, settings.create, settings.delete
  resource  String   // Resource type: settings, user, role, etc.
  resourceId String? // Resource ID (e.g., settings key)
  oldValue  Json?    // Old value (for updates)
  newValue  Json?    // New value
  metadata  Json?    // Additional metadata
  createdAt DateTime @default(now())

  @@map("audit_logs")
  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
}

// Enum for channel queue status
enum ChannelQueueStatus {
  queued
  sent
  failed
}

// ChannelQueue model for scheduled channel posts
model ChannelQueue {
  id          String            @id @default(uuid())
  payload     Json              // Message payload (templateKey, variables, buttons, etc.)
  status      ChannelQueueStatus @default(queued)
  scheduledAt DateTime?         // When to send (null = send immediately)
  sentAt      DateTime?         // When message was sent
  messageId   Int?              // Telegram message ID after sending
  attempts    Int               @default(0)
  lastError   String?           // Last error message if failed
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("channel_queue")
  @@index([status])
  @@index([scheduledAt])
  @@index([status, scheduledAt])
}

