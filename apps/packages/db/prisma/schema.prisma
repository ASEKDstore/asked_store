// Prisma schema for ASKED Store

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Telegram user model
model TelegramUser {
  id         String   @id @default(uuid())
  tgId       BigInt   @unique @db.BigInt
  username   String?
  firstName  String?
  lastName   String?
  role       String   @default("user") // RBAC: "user", "admin", etc.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("telegram_users")
  @@index([tgId])
  @@index([role])
}

