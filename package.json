{
  "name": "asked",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:backend": "npm --workspace apps/backend run dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "dev:bot": "npm --workspace apps/bot run dev",
    "install:all": "npm install --workspaces",
    "build:backend": "npm --workspace apps/backend run build",
    "build:frontend": "npm --workspace apps/frontend run build",
    "where": "node -e \"const fs=require('fs'); const p=['apps/backend','backend','apps/frontend','frontend','apps/bot','bot']; for (const x of p) console.log(x, fs.existsSync(x)?'✅':'❌');\""
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}



